# Provider selection: ollama | groq | openai | llama-cpp
# For a fallback chain (tried left-to-right on failure), use P1_PROVIDER_CHAIN instead:
# P1_PROVIDER_CHAIN=groq,ollama
P1_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# --- Groq ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_API_KEY=ollama
# OLLAMA_TEMPERATURE=0.3
# OLLAMA_NUM_CTX=32768
# OLLAMA_USE_NATIVE_CHAT_API=true
# OLLAMA_TIMEOUT=150
# OLLAMA_NUM_GPU=0          # set to 0 to force CPU (workaround for broken Vulkan on Intel Arc)
# OLLAMA_THINKING_BUDGET_TOKENS=0
# OLLAMA_THINKING_MAX_TOKENS=0

# --- llama-cpp (SYCL / CPU / llama-server) ---
# LLAMA_CPP_BASE_URL=http://127.0.0.1:8080/v1
# LLAMA_CPP_MODEL=auto                                    # auto-detects loaded model via GET /v1/models
# LLAMA_CPP_MODEL=Qwen3-8B-Q4_K_M.gguf                  # best pick — newest arch, strong tool-use, ~4.7 GB
# LLAMA_CPP_MODEL=Qwen3-14B-Q4_0.gguf                   # highest quality, slow on CPU, ~8.5 GB
# LLAMA_CPP_MODEL=qwen2.5-7b-instruct-q4_0.gguf         # fast, reliable JSON, ~4.1 GB
# LLAMA_CPP_MODEL=qwen2.5-14b-instruct-q4_0.gguf        # better quality Qwen2.5, ~8.5 GB
# LLAMA_CPP_MODEL=Llama-3.2-3B-Instruct-Q5_K_M.gguf    # fastest option, ~2.3 GB
# LLAMA_CPP_MODEL=phi-4-Q4_K_M.gguf                     # Microsoft Phi-4, strong reasoning, ~8.4 GB
# LLAMA_CPP_TIMEOUT=60.0
# LLAMA_CPP_THINKING=true
# LLAMA_CPP_GRAMMAR=0  # grammar is ENABLED by default; set to 0 to disable GBNF enforcement

# --- Provider tuning ---
P1_PROVIDER_TIMEOUT_SECONDS=30
P1_PROVIDER_MAX_RETRIES=2
P1_PROVIDER_RETRY_BACKOFF_SECONDS=1.0
P1_PLAN_CALL_TIMEOUT_SECONDS=45

# --- Langfuse (optional) ---
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Postgres (production) ---
# DATABASE_URL=postgresql://agentic:agentic@localhost:5433/agentic_workflows
# When DATABASE_URL is set, all stores (runs, checkpoints, memos) use Postgres.
# When absent, SQLite files in .tmp/ are used (dev/test default).
# docker-compose.yml maps Postgres to port 5433 (avoids conflict with local installs).

# --- Semantic context / RAG (Phase 7.3) ---
# EMBEDDING_PROVIDER=mock       # mock (default, no download) | fastembed (downloads ~24MB model)
# fastembed uses BAAI/bge-small-en-v1.5 (384-dim). Requires: pip install ".[context]"

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
RUN_STORE_DB=.tmp/run_store.db
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# SSE_MAX_DURATION_SECONDS=1800   # 30 min — long Ollama multi-mission runs can exceed 5 min
# API_KEY=                        # leave unset for dev passthrough (no auth enforced)

# --- Tool permissions ---
# P1_BASH_ENABLED=true
# P1_TOOL_SANDBOX_ROOT=/path/to/sandbox     # restrict file tools to this directory
# P1_BASH_DENIED_PATTERNS=rm -rf,mkfs,dd if=  # comma-separated substrings to block
# P1_BASH_ALLOWED_COMMANDS=ls,cat,echo        # always-allowed command prefixes
# P1_HTTP_ALLOWED_DOMAINS=api.github.com      # comma-separated domain allowlist
# P1_HTTP_MAX_RESPONSE_BYTES=10485760         # 10 MB response cap
# P1_WRITE_FILE_MAX_BYTES=10485760            # 10 MB write cap
# P1_READ_FILE_MAX_BYTES=10485760             # 10 MB read output cap
# P1_USER_INPUT_MAX_LENGTH=50000              # user input character limit
