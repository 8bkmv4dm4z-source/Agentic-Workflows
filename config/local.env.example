# Local Ollama configuration for magistral (reasoning model).
# Copy to .env and adjust as needed.

P1_PROVIDER=ollama

# Ollama server
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=magistral

# Context window.  LocalAgent calls ensure_model() on startup, which creates a
# "magistral-32k" Modelfile variant so Ollama never silently truncates prompts.
OLLAMA_NUM_CTX=32000

# Magistral is a reasoning model; allow longer generation time.
OLLAMA_TIMEOUT=300
